# =========================
# IntelliJ IDEA / JetBrains
# =========================
.idea/
*.iml
*.ipr
*.iws
out/

# JetBrains workspace/cache files (keep project config local)
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries/
.idea/**/shelf/

# Optional: if you want to keep shared run configs, remove this line
.idea/runConfigurations/

# =========================
# Maven / Java build output
# =========================
target/
dependency-reduced-pom.xml

# Compiled Java classes / archives (extra safety)
*.class
*.jar
*.war
*.ear

# =========================
# Logs
# =========================
*.log

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db
Desktop.ini

# =========================
# Environment / local config
# =========================
.env
.env.*
!.env.example

# =========================
# Java crash logs
# =========================
hs_err_pid*
replay_pid*
